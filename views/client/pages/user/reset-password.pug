extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
    +alert-error(5000)

    .container.my-5
        .row.justify-content-center
            .col-8
                h1(class="text-center mb-4") Đổi mật khẩu

                form(
                    action="/user/password/reset"
                    method="POST"
                )
                    .mb-3
                        label(for="password") Mật khẩu mới
                        input.form-control(
                            type="password"
                            id="password"
                            name="password"
                            required
                        )

                    .mb-3
                        label(for="confirmPassword") Xác nhận mật khẩu
                        input.form-control(
                            type="password"
                            id="confirmPassword"
                            name="confirmPassword"
                            required
                        )

                    .mb-3
                        button.btn.btn-primary.w-100(
                            type="submit"
                        ) Đổi mật khẩu