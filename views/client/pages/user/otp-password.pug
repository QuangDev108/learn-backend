extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
    +alert-error(5000)

    .container.my-5
        .row.justify-content-center
            .col-8
                h1(class="text-center mb-4") Nhập mã OTP xác thực

                form(
                    action="/user/password/otp"
                    method="POST"
                )
                    .mb-3
                        label(for="email") Email
                        input.form-control(
                            type="email"
                            id="email"
                            name="email"
                            required
                            value=email
                            readonly
                        )

                    .mb-3
                        label(for="otp") Mã OTP
                        input.form-control(
                            type="text"
                            id="otp"
                            name="otp"
                            required
                        )

                    .mb-3
                        button.btn.btn-primary.w-100(
                            type="submit"
                        ) Xác nhận